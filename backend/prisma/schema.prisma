datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Tenant {
  id             String        @id @default(uuid())
  name           String
  subdomain      String        @unique
  customDomain   String?       @unique @map("custom_domain")
  logoUrl        String?       @map("logo_url")
  primaryColor   String        @default("#C5A880") @map("primary_color")
  secondaryColor String        @default("#18181b") @map("secondary_color")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  users          User[]
  clients        Client[]
  services       Service[]
  products       Product[]
  appointments   Appointment[]
  quickReplies   QuickReply[]
  goals          Goal[]
  auditLogs      AuditLog[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String
  role      String   @default("BARBER") // "SUPER_ADMIN" | "ADMIN" | "ATTENDANT" | "BARBER"
  roles     String[] @default([])
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  barber    Barber?

  tenantId  String? @map("tenant_id")
  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("users")
}

model Barber {
  id            String        @id @default(uuid())
  userId        String        @unique @map("user_id")
  categoria     String        @default("BARBER")
  especialidade String
  miniBio       String?       @map("mini_bio")
  commissionRate Float        @default(50) @map("commission_rate")
  notaMedia     Float         @default(5.0) @map("nota_media")
  fotoUrl       String?       @map("foto_url")
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  services       Service[]     @relation("BarberServices")
  productCommissions ProductCommission[]
  serviceCommissions ServiceCommission[]
  workSchedules WorkSchedule[]
  agendaBlocks AgendaBlock[]
  assignedClients Client[] @relation("AssignedBarber")

  @@map("barbers")
}

model Client {
  id               String        @id @default(uuid())
  nome             String
  telefone         String        @unique
  email            String?
  aniversario      String?
  observacoes      String?
  preferences      String?
  frequency        Int           @default(0)
  ticketMedio      Float         @default(0.0) @map("ticket_medio")
  chatStatus       String        @default("NEW") @map("chat_status")
  origem           String?
  tags             String[]      @default([])
  assignedBarberId String?       @map("assigned_barber_id")
  assignedBarber   Barber?       @relation("AssignedBarber", fields: [assignedBarberId], references: [id], onDelete: SetNull)
  createdAt        DateTime      @default(now()) @map("created_at")
  appointments     Appointment[]
  messages         Message[]

  tenantId  String? @map("tenant_id")
  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("clients")
}

model Service {
  id                String              @id @default(uuid())
  nome              String
  preco             Float
  duracao           Int // em minutos
  descricao         String?
  appointments      Appointment[]
  barbers           Barber[]            @relation("BarberServices")
  customCommissions ServiceCommission[]

  tenantId  String? @map("tenant_id")
  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("services")
}

model Product {
  id        String   @id @default(uuid())
  nome      String
  preco     Float
  descricao String?
  commissionRate Float    @default(0) @map("commission_rate")
  customCommissions ProductCommission[]
  createdAt DateTime @default(now()) @map("created_at")

  tenantId  String? @map("tenant_id")
  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("products")
}

model ProductCommission {
  id             String   @id @default(uuid())
  productId      String   @map("product_id")
  barberId       String   @map("barber_id")
  commissionRate Float    @map("commission_rate")
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  barber         Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([productId, barberId])
  @@map("product_commissions")
}

model Appointment {
  id         String   @id @default(uuid())
  clientId   String   @map("client_id")
  barberId   String   @map("barber_id")
  serviceId  String   @map("service_id")
  data       DateTime
  status     String   @default("SCHEDULED") // "SCHEDULED" | "CONFIRMED" | "CHECKED_IN" | "IN_PROGRESS" | "COMPLETED" | "CANCELLED"
  valor      Float
  createdAt  DateTime @default(now()) @map("created_at")
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  barber     Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  service    Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  feedback   Feedback?

  tenantId  String? @map("tenant_id")
  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("appointments")
}

model Feedback {
  id            String      @id @default(uuid())
  appointmentId String      @unique @map("appointment_id")
  nota          Int
  comentario    String?
  ratingBarber  Int         @default(5) @map("rating_barber")
  ratingEnv     Int         @default(5) @map("rating_env")
  ratingPunctual String?    @map("rating_punctual") // simplified
  createdAt     DateTime    @default(now()) @map("created_at")
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@map("feedbacks")
}

model Message {
  id        String   @id @default(uuid())
  clientId  String   @map("client_id")
  mensagem  String
  tipo      String   // "SENT" | "RECEIVED"
  createdAt DateTime @default(now()) @map("created_at")
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model WorkSchedule {
  id          String   @id @default(uuid())
  barberId    String   @map("barber_id")
  dayOfWeek   Int      // 0 (Domingo) a 6 (Sábado)
  startTime   String   // "09:00"
  endTime     String   // "18:00"
  breakStart  String?  @map("break_start")
  breakEnd    String?  @map("break_end")
  active      Boolean  @default(true)
  barber      Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([barberId, dayOfWeek])
  @@map("work_schedules")
}

model AgendaBlock {
  id          String   @id @default(uuid())
  barberId    String   @map("barber_id")
  titulo      String   // Ex: "Férias", "Almoço", "Médico"
  dataInicio  DateTime @map("data_inicio")
  dataFim     DateTime @map("data_fim")
  barber      Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@map("agenda_blocks")
}

model QuickReply {
  id        String   @id @default(uuid())
  titulo    String
  conteudo  String
  createdAt DateTime @default(now()) @map("created_at")

  tenantId  String? @map("tenant_id")
  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("quick_replies")
}

model Goal {
  id          String   @id @default(uuid())
  titulo      String
  tipo        String   // "BILLING" | "SERVICES"
  valorAlvo   Float    @map("valor_alvo")
  valorAtual  Float    @default(0.0) @map("valor_atual")
  dataInicio  DateTime @map("data_inicio")
  dataFim     DateTime @map("data_fim")

  tenantId  String? @map("tenant_id")
  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("goals")
}

model AuditLog {
  id        String   @id @default(uuid())
  usuario   String
  acao      String
  detalhes  String?
  createdAt DateTime @default(now()) @map("created_at")

  tenantId  String? @map("tenant_id")
  tenant    Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}

model ServiceCommission {
  id             String   @id @default(uuid())
  serviceId      String   @map("service_id")
  barberId       String   @map("barber_id")
  commissionRate Float    @map("commission_rate")
  service        Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  barber         Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([serviceId, barberId])
  @@map("service_commissions")
}
