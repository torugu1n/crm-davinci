{
  "name": "crm-davinci-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "pnpm run prisma:generate && nest build",
    "dev": "pnpm run start:dev",
    "start": "nest start",
    "start:dev": "pnpm run prisma:generate && nest start --watch",
    "start:prod": "pnpm exec prisma migrate deploy && pnpm run prisma:generate && node dist/src/main",
    "prisma:generate": "mkdir -p .cache/prisma && XDG_CACHE_HOME=$(pwd)/.cache pnpm exec prisma generate --schema=./prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/platform-socket.io": "^10.0.0",
    "@nestjs/websockets": "^10.0.0",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "glob": "^13.0.6",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "socket.io": "^4.7.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^3.0.9",
    "commander": "^14.0.3",
    "jiti": "^2.7.0",
    "prisma": "^6.19.3",
    "source-map-support": "^0.5.21",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "bcryptjs"
    ]
  }
}
